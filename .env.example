# =====================
# Database
# =====================
DB_URL=jdbc:postgresql://your_db_host:5432/postgres
DB_USERNAME=your_username
DB_PASSWORD=your_password

# =====================
# JWT
# =====================
JWT_SECRET=your_jwt_secret_here

# =====================
# Mail
# =====================
MAIL_USERNAME=your_gmail_address
MAIL_PASSWORD=your_app_password
APP_FRONTEND_URL=http://localhost:5173

# =====================
# Google OAuth2
# =====================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# =====================
# GHN Config
# =====================
GHN_API_URL=https://dev-online-gateway.ghn.vn/shiip/public-api
GHN_API_TOKEN=your_ghn_token_here
GHN_SHOP_ID=your_ghn_shop_id_here

# =====================
# Sepay Config
# =====================
SEPAY_API_TOKEN=your_sepay_token
SEPAY_WEBHOOK_KEY=your_webhook_key
SEPAY_BANK_ACCOUNT_ID=your_account_id
SEPAY_ACCOUNT_NUMBER=your_account_number
SEPAY_ACCOUNT_NAME=your_account_name
AUTH_PASSWORD_RESET_EXPIRATION=3600000

// =====================
